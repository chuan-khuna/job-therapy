# =============================================================================
# Job Therapy — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values:
#
#     cp .env.example .env.local
#
# `.env.local` is git-ignored — NEVER commit real keys. Only this `.env.example`
# (placeholders only) is tracked. Variables prefixed with NEXT_PUBLIC_ are
# exposed to the browser; everything else is server-only.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — client (REQUIRED)
# -----------------------------------------------------------------------------
# Project URL and the publishable key. Safe to expose to the browser: the
# publishable key only grants what your Row Level Security (RLS) policies
# allow — it is NOT a secret. (In older projects this was called the "anon"
# key; the value is interchangeable in the client.)
# Find both in the Supabase dashboard → Project Settings → API keys.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."


# -----------------------------------------------------------------------------
# Supabase — server (REQUIRED for server-side admin work)
# -----------------------------------------------------------------------------
# The secret key BYPASSES Row Level Security. Use it ONLY in server code
# (server actions / route handlers), NEVER in the browser and NEVER with a
# NEXT_PUBLIC_ prefix. Leaking this key exposes all users' data.
# (In older projects this was the "service_role" key — same power.)
# Dashboard → Project Settings → API keys → secret key.
SUPABASE_SECRET_KEY="sb_secret_..."


# -----------------------------------------------------------------------------
# App URL (REQUIRED for OAuth redirects)
# -----------------------------------------------------------------------------
# The site's own base URL, used to build the OAuth `redirectTo` callback.
# Local dev: http://localhost:3000   Production: your deployed origin.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# Discord login
# -----------------------------------------------------------------------------
# NOTE: With Supabase Auth, the Discord Client ID + Secret are entered in the
# Supabase dashboard (Authentication → Providers → Discord), NOT in this file.
# In the Discord Developer Portal, set the OAuth2 redirect URL to:
#     https://your-project-ref.supabase.co/auth/v1/callback
# These two are recorded here only for reference / your own notes — the app
# does not read them at runtime.
# DISCORD_CLIENT_ID="your-discord-application-id"
# DISCORD_CLIENT_SECRET="your-discord-client-secret"


# -----------------------------------------------------------------------------
# Supabase CLI / migrations (OPTIONAL — local tooling only)
# -----------------------------------------------------------------------------
# Used by the Supabase CLI to link the project and push SQL migrations
# (supabase/migrations/). Not needed at app runtime.
#   - SUPABASE_PROJECT_REF: dashboard → Project Settings → General → Reference ID
#   - SUPABASE_DB_PASSWORD: the database password set when the project was created
#   - DATABASE_URL: direct Postgres connection string (pooler), for running raw
#     SQL or other DB tools against the database.
# SUPABASE_PROJECT_REF="your-project-ref"
# SUPABASE_DB_PASSWORD="your-database-password"
# DATABASE_URL="postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres"
