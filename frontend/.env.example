# =============================================================================
# Job Therapy — frontend environment variables
# =============================================================================
# Copy this file to `.env.local` and adjust as needed:
#
#     cp .env.example .env.local
#
# `.env.local` is git-ignored — only this `.env.example` is tracked.
# =============================================================================


# -----------------------------------------------------------------------------
# Backend API (server-only)
# -----------------------------------------------------------------------------
# Base URL of the FastAPI backend that owns the database. Read on the server
# (Server Components / Server Actions) in lib/api/results.ts — NOT exposed to
# the browser, so no NEXT_PUBLIC_ prefix. Defaults to the local dev server when
# unset.
BACKEND_URL="http://localhost:8000"
